# Базовий образ — Python 3.13 на Alpine Linux
# Alpine — мінімалістичний Linux (~5MB), завдяки чому образ важить ~50MB замість ~900MB
FROM python:3.13-alpine

# Встановлюємо робочу директорію всередині контейнера
# Всі наступні команди (COPY, RUN, CMD) виконуються відносно /app
# Якщо директорія не існує — Docker створить її автоматично
WORKDIR /app

# Спочатку копіюємо ТІЛЬКИ requirements.txt (без коду)
# Це дозволяє Docker кешувати шар із залежностями окремо від коду
# Якщо requirements.txt не змінився — pip не перевстановлюватиме пакети при наступному білді
COPY requirements.txt .

# Встановлюємо Python залежності
# --no-cache-dir — не зберігати кеш pip всередині образу, зменшує розмір фінального образу
RUN pip install --no-cache-dir -r requirements.txt

# Копіюємо код застосунку ПІСЛЯ залежностей
# Зміни в коді не інвалідують кеш pip — Docker перебілдить лише цей шар і далі
COPY src/ .

# Документуємо що застосунок слухає порт 8080
# EXPOSE — це лише метадата, реально порт не відкривається
# Відкриття порту назовні відбувається через ports: в docker-compose.yaml
EXPOSE 8080

# Команда запуску застосунку при старті контейнера
# uvicorn   — ASGI сервер для FastAPI
# main:app  — файл main.py, об'єкт app = FastAPI()
# --host 0.0.0.0  — слухати на всіх мережевих інтерфейсах (не тільки localhost)
#                   без цього застосунок був би недоступний ззовні контейнера
# --port 8080     — порт який слухає застосунок
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8080"]
